# Claudia (claudia) chatbot configuration - example .env
# Copy to ~/whisplay-ai-chatbot/.env on the Pi, fill in your key, save.
# The upstream template at github.com/PiSugar/whisplay-ai-chatbot/blob/master/.env.template
# is the source of truth - diff against it after every repo update.
#
# Server-selector keys are *_SERVER (not *_PROVIDER). Upstream's plugin
# registry switches by lowercase name: see src/cloud-api/server.ts.

# === LLM (the AI brain) ===
LLM_SERVER=anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === System prompt - shapes the assistant's voice ===
SYSTEM_PROMPT=You are a concise, friendly voice assistant. Answer in plain spoken English - no markdown, no bullet lists, no headings. Keep responses to 1-3 sentences unless the user explicitly asks for more.

# === Speech-to-text (ASR) ===
# Upstream values: test, openai, gemini, google, tencent, volcengine, whisper-cpp, ...
# 'whisper-cpp' -> local, no extra API keys, slowest on a Pi Zero 2 W
# 'openai'      -> cloud, fast, needs OPENAI_API_KEY
ASR_SERVER=whisper-cpp

# === Text-to-speech (TTS) ===
# Upstream values: test, openai, gemini, tencent, volcengine, piper, piper-http,
#                  espeak-ng, llm8850melotts, supertonic, picovoice
# 'openai'    -> cloud, near-state-of-the-art voices (gpt-4o-mini-tts)
# 'piper'     -> local, free, "robot but understandable"
# 'elevenlabs' -> ONLY works if you applied the ElevenLabs patch (see build guide)
TTS_SERVER=openai

# --- OpenAI TTS sub-keys (used when TTS_SERVER=openai) ---
OPENAI_API_KEY=sk-REPLACE-ME
OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_VOICE_TYPE=nova

# --- ElevenLabs sub-keys (used when TTS_SERVER=elevenlabs; requires patch) ---
# ELEVENLABS_API_KEY=sk_REPLACE_ME
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY=0.75

# === Wake-word activation ===
# Wake-word detection runs on the Hiwonder WonderEcho module over I2C - no
# Pi-side wake-word listener. See the build guide section 08.3 for the
# I2C programming script that sets the trigger word to "Claudia".
